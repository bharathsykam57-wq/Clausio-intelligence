{
  "$schema": "https://schema.railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd backend && pip3 install -r requirements.txt"
  },
  "deploy": {
    "startCommand": "cd backend && uvicorn api.main:app --host 0.0.0.0 --port $PORT",
    "healthcheckPath": "/health",
    "restartPolicyType": "ON_FAILURE"
  }
}
